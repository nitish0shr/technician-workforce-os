{
  "name": "technician-workforce-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Market-level technician workforce planning operating system.",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "build:desktop": "node tools/build-desktop.mjs",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "seed": "node server/seed.js",
    "test": "node --test server/*.test.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express": "^4.19.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@tanstack/react-table": "^8.20.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "lucide-react": "^0.439.0",
    "postcss": "^8.4.41",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "recharts": "^2.12.7",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "engines": {
    "node": ">=18"
  }
}
